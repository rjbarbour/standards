---
import BaseLayout from "../../layouts/BaseLayout.astro";

const items = [
  {
    title: "README.llm vNext proposal",
    href: "/readme-llm-vnext/",
    description:
      "The full proposal text defining the extension itself.",
  },
  {
    title: "OSSS proposal",
    href: "/osss-proposal/",
    description:
      "The related proposal for specification structure and proposal design.",
  },
  {
    title: "Why Diataxis fits README.llm vNext",
    href: "/explanation/diataxis-and-readme-llm-vnext/",
    description:
      "A conceptual note on using Diataxis as a human-facing organization layer around the standard.",
  },
];
---

<BaseLayout
  title="Explanation"
  description="Conceptual and rationale-oriented material for understanding the standards and the site's documentation structure."
  eyebrow="Diataxis Example"
>
  <section class="landing-grid">
    <article class="spotlight-card">
      <p class="kicker">Purpose</p>
      <h2>Explain ideas, tradeoffs, and rationale</h2>
      <p>
        Explanation is where conceptual understanding lives. It is the right
        place for proposals, rationale, comparisons, and architectural
        interpretation.
      </p>
    </article>

    <aside class="signal-card">
      <p class="kicker">Lens</p>
      <ul class="signal-list">
        <li>Conceptual depth</li>
        <li>Rationale and tradeoffs</li>
        <li>Not task-first, not reference-first</li>
      </ul>
    </aside>
  </section>

  <section class="library-section">
    <div class="section-heading">
      <p class="kicker">Available</p>
      <h2>Explanation routes</h2>
    </div>

    <section class="standards-grid">
      {items.map((item) => (
        <article class="standard-card">
          <p class="kicker">Explanation</p>
          <h2><a href={item.href}>{item.title}</a></h2>
          <p>{item.description}</p>
          <a class="text-link" href={item.href}>Open explanation</a>
        </article>
      ))}
    </section>
  </section>
</BaseLayout>
