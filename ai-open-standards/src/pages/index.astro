---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageModules = import.meta.glob("./*.md", { eager: true });
const pages = Object.values(pageModules);
const items = pages
  .map((p) => ({
    url: p.url ?? "",
    title: p.frontmatter?.title ?? "",
    description: p.frontmatter?.description ?? "",
  }))
  .filter((i) => i.url)
  .sort((a, b) => String(a.title).localeCompare(String(b.title)));
---

<BaseLayout
  title="Working drafts for machine-readable standards"
  description="A small editorial library of specifications and proposals focused on AI-era documentation and process design."
  eyebrow="Curated Drafts"
>
  <section class="landing-grid">
    <article class="spotlight-card">
      <p class="kicker">Current focus</p>
      <h2>Specifications designed to be read by humans and machines</h2>
      <p>
        This project collects draft standards that formalize structure, retrieval,
        and proposal design without turning the documents into bureaucracy.
      </p>
      <div class="button-row">
        <a class="button-primary" href="#library">Browse the library</a>
        <a class="button-secondary" href="https://github.com/rjbarbour/standards">View source</a>
      </div>
    </article>

    <aside class="signal-card">
      <p class="kicker">Themes</p>
      <ul class="signal-list">
        <li>Specification structure without procedural bloat</li>
        <li>Retrieval-aware documentation for agent workflows</li>
        <li>Readable public drafts with a clear editorial voice</li>
      </ul>
    </aside>
  </section>

  <section class="library-section" id="library">
    <div class="section-heading">
      <p class="kicker">Library</p>
      <h2>Current drafts</h2>
    </div>

    <section class="standards-grid">
      {items.map((i) => (
        <article class="standard-card">
          <p class="kicker">Draft standard</p>
          <h2><a href={i.url}>{i.title}</a></h2>
          {i.description ? <p>{i.description}</p> : null}
          <a class="text-link" href={i.url}>Open document</a>
        </article>
      ))}
    </section>
  </section>
</BaseLayout>
