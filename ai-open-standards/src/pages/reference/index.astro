---
import BaseLayout from "../../layouts/BaseLayout.astro";

const items = [
  {
    title: "Manifest and schema reference",
    href: "/reference/manifest-and-schema/",
    description:
      "A compact reference page for the live manifest, the canonical schema, and their intended roles.",
  },
];
---

<BaseLayout
  title="Reference"
  description="Lookup-oriented reference material for the README.llm vNext example implementation on this site."
  eyebrow="Diataxis Example"
>
  <section class="landing-grid">
    <article class="spotlight-card">
      <p class="kicker">Purpose</p>
      <h2>Be exact, structured, and easy to scan</h2>
      <p>
        Reference content is for precise facts: file locations, schemas,
        required fields, and stable artifacts that other tools can depend on.
      </p>
    </article>

    <aside class="signal-card">
      <p class="kicker">Lens</p>
      <ul class="signal-list">
        <li>Lookup over narrative</li>
        <li>Stable facts over guidance</li>
        <li>Precise links and field names</li>
      </ul>
    </aside>
  </section>

  <section class="library-section">
    <div class="section-heading">
      <p class="kicker">Available</p>
      <h2>Reference routes</h2>
    </div>

    <section class="standards-grid">
      {items.map((item) => (
        <article class="standard-card">
          <p class="kicker">Reference</p>
          <h2><a href={item.href}>{item.title}</a></h2>
          <p>{item.description}</p>
          <a class="text-link" href={item.href}>Open reference</a>
        </article>
      ))}
    </section>
  </section>
</BaseLayout>
