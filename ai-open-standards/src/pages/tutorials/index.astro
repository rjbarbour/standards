---
import BaseLayout from "../../layouts/BaseLayout.astro";

const items = [
  {
    title: "First README.llm vNext documentation set",
    href: "/tutorials/first-documentation-set/",
    description:
      "A guided walkthrough for turning a single README.llm file into a small multi-file documentation set.",
  },
];
---

<BaseLayout
  title="Tutorials"
  description="Guided, sequential walkthroughs showing what a README.llm vNext documentation set looks like in practice."
  eyebrow="Diataxis Example"
>
  <section class="landing-grid">
    <article class="spotlight-card">
      <p class="kicker">Purpose</p>
      <h2>Learn by building one complete thing</h2>
      <p>
        Tutorial content is for first-time adoption. It should be sequential,
        beginner-tolerant, and focused on completing a coherent workflow rather
        than serving as a lookup reference.
      </p>
    </article>

    <aside class="signal-card">
      <p class="kicker">Lens</p>
      <ul class="signal-list">
        <li>Start from little context</li>
        <li>Follow an ordered path</li>
        <li>Optimize for confidence, not speed</li>
      </ul>
    </aside>
  </section>

  <section class="library-section">
    <div class="section-heading">
      <p class="kicker">Available</p>
      <h2>Tutorial routes</h2>
    </div>

    <section class="standards-grid">
      {items.map((item) => (
        <article class="standard-card">
          <p class="kicker">Tutorial</p>
          <h2><a href={item.href}>{item.title}</a></h2>
          <p>{item.description}</p>
          <a class="text-link" href={item.href}>Open tutorial</a>
        </article>
      ))}
    </section>
  </section>
</BaseLayout>
